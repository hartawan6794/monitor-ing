                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/dashboard/summary": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Ringkasan penjualan (Omzet, Laba, Margin)",
                "description": "Menghitung omzet, laba kotor, dan margin untuk 4 periode: hari ini, minggu ini, bulan ini, dan tahun ini.",
                "operationId": "892e76df1345997e0682213c6fbbb52d",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/X-Server-IP"
                    },
                    {
                        "$ref": "#/components/parameters/X-Database-Name"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Username"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Password"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sukses"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/dashboard/salesman-view": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Dashboard Salesman",
                "description": "Mengambil data total penjualan, return penjualan, penjualan tunai, penerimaan piutang, biaya operasional, kas di tangan dan penjualan & order 7 hari terakhir.",
                "operationId": "89176552893d2c50c7af623c184bfa88",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/X-Server-IP"
                    },
                    {
                        "$ref": "#/components/parameters/X-Database-Name"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Username"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Password"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sukses"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/server/check": {
            "post": {
                "tags": [
                    "Dynamic Connection"
                ],
                "summary": "Cek Server",
                "description": "Memeriksa apakah server terdaftar dan memiliki database aktif.",
                "operationId": "ff6afa4e360de20aaf3313be1f599d1e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "ip_address"
                                ],
                                "properties": {
                                    "ip_address": {
                                        "type": "string",
                                        "example": "[IP_ADDRESS]"
                                    },
                                    "username": {
                                        "type": "string",
                                        "example": "admin"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Server valid",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "data": {
                                            "properties": {
                                                "server_name": {
                                                    "type": "string",
                                                    "example": "Server 1"
                                                },
                                                "ip_address": {
                                                    "type": "string",
                                                    "example": "[IP_ADDRESS]"
                                                },
                                                "total_db": {
                                                    "type": "integer",
                                                    "example": 2
                                                },
                                                "databases": {
                                                    "properties": {
                                                        "db1": {
                                                            "type": "string",
                                                            "example": "Database 1"
                                                        },
                                                        "db2": {
                                                            "type": "string",
                                                            "example": "Database 2"
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Server tidak ditemukan atau tidak aktif"
                    }
                }
            }
        }
    },
    "components": {
        "parameters": {
            "X-Server-IP": {
                "name": "X-Server-IP",
                "in": "header",
                "description": "Alamat server untuk koneksi database",
                "required": true,
                "schema": {
                    "type": "string"
                }
            },
            "X-Database-Name": {
                "name": "X-Database-Name",
                "in": "header",
                "description": "Nama database yang digunakan",
                "required": true,
                "schema": {
                    "type": "string"
                }
            },
            "X-DB-Username": {
                "name": "X-DB-Username",
                "in": "header",
                "description": "Username untuk koneksi database",
                "required": true,
                "schema": {
                    "type": "string"
                }
            },
            "X-DB-Password": {
                "name": "X-DB-Password",
                "in": "header",
                "description": "Password untuk koneksi database",
                "required": true,
                "schema": {
                    "type": "string"
                }
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Masukkan token dari endpoint /login. Format: Bearer {token}",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Dashboard",
            "description": "Dashboard"
        },
        {
            "name": "Dynamic Connection",
            "description": "Dynamic Connection"
        }
    ]
}