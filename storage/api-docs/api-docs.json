{
    "openapi": "3.0.0",
    "info": {
        "title": "Montor-ing API",
        "description": "Dokumentasi API untuk aplikasi Montor-ing (Inventory & Sales Monitoring).",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "Server API Utama"
        }
    ],
    "paths": {
        "/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login pengguna",
                "description": "Autentikasi pengguna menggunakan ID dan password.",
                "operationId": "67d6d0fdd54fba132e1b6f55ca254183",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/X-Server-IP"
                    },
                    {
                        "$ref": "#/components/parameters/X-Database-Name"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Username"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Password"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id",
                                    "userpassword"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "string",
                                        "example": "john"
                                    },
                                    "userpassword": {
                                        "type": "string",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "data": {
                                            "properties": {
                                                "token": {
                                                    "type": "string",
                                                    "example": "1|abc123..."
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "/dashboard": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Ringkasan penjualan",
                "description": "Mengambil total penjualan untuk 4 periode.",
                "operationId": "fa2272983cbe8d142dcd03ed9eee1dd1",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/X-Server-IP"
                    },
                    {
                        "$ref": "#/components/parameters/X-Database-Name"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Username"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Password"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sukses",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/dashboard/salesman": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Penjualan harian per salesman",
                "description": "Mengambil total penjualan masing-masing salesman untuk hari ini.",
                "operationId": "1a57f1cacecb6795c50899a489a506b7",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/X-Server-IP"
                    },
                    {
                        "$ref": "#/components/parameters/X-Database-Name"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Username"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Password"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sukses"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/dashboard/salesman/yearly": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Penjualan tahunan per salesman",
                "description": "Mengambil total penjualan masing-masing salesman sepanjang tahun berjalan.",
                "operationId": "a52f8d40c6bc3ccd6bf42b5466c3dcc6",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/X-Server-IP"
                    },
                    {
                        "$ref": "#/components/parameters/X-Database-Name"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Username"
                    },
                    {
                        "$ref": "#/components/parameters/X-DB-Password"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sukses"
                    },
                    "401": {
